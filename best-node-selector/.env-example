# Best Node Selector Configuration
# Copy this file to .env and adjust values as needed

# Server port
PORT=9000

# Metrics provider: "http" or "sample"
METRICS_PROVIDER=http

# Metrics service base URL (e.g., your observability service)
METRICS_BASE_URL=http://localhost:3000

# Metrics request timeout in milliseconds
METRICS_TIMEOUT_MS=10

# Time window for metrics aggregation (seconds)
TIME_WINDOW_SECONDS=10

# Top K peers to consider for scheduling decisions
TOPK_PEERS=1

# Target service ID (namespace:service format)
TARGET_SERVICE_ID=default:checkoutservice

# Namespaces to watch for scheduling decisions (comma-separated)
WATCH_NAMESPACES=default

# Redis address for storing decisions
REDIS_ADDR=localhost:6379

# Enable/disable background score updates
ENABLE_SCORE_UPDATE=true

# How often to recompute scores (seconds)
SCORER_INTERVAL_SEC=10

# Kubernetes config (optional, uses in-cluster config if not set)
# KUBECONFIG=~/.kube/config
